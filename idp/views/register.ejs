<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Account - Secure SSO</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-color: #0b0c10;
      --card-bg: rgba(22, 26, 37, 0.65);
      --card-border: rgba(255, 255, 255, 0.08);
      --accent-color: #bd00ff;
      --accent-hover: #9c00d4;
      --text-main: #f5f6f9;
      --text-muted: #8b949e;
      --error-color: #ff4a5a;
      --error-bg: rgba(255, 74, 90, 0.1);
    }
    
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    body {
      font-family: 'Outfit', sans-serif;
      background: radial-gradient(circle at 50% 0%, #171c28 0%, #08090d 100%);
      color: var(--text-main);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow-x: hidden;
    }
    
    .container {
      width: 100%;
      max-width: 440px;
      padding: 20px;
      perspective: 1000px;
    }
    
    .card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      padding: 40px 32px;
      backdrop-filter: blur(16px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 100px rgba(189, 0, 255, 0.05);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .card:hover {
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.6), 0 0 120px rgba(189, 0, 255, 0.08);
    }
    
    .header {
      text-align: center;
      margin-bottom: 32px;
    }
    
    .logo {
      font-size: 32px;
      font-weight: 700;
      background: linear-gradient(135deg, #00e6ff 0%, #bd00ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 8px;
      letter-spacing: -0.5px;
    }
    
    .subtitle {
      color: var(--text-muted);
      font-size: 14px;
    }
    
    .form-group {
      margin-bottom: 20px;
      position: relative;
    }
    
    .form-label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .form-control {
      width: 100%;
      background: rgba(8, 9, 13, 0.6);
      border: 1px solid var(--card-border);
      border-radius: 10px;
      padding: 14px 16px;
      color: var(--text-main);
      font-family: inherit;
      font-size: 15px;
      transition: all 0.3s ease;
    }
    
    .form-control:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 15px rgba(189, 0, 255, 0.15);
      background: rgba(8, 9, 13, 0.8);
    }
    
    .btn {
      width: 100%;
      background: linear-gradient(135deg, #bd00ff 0%, #8b00ff 100%);
      border: none;
      border-radius: 10px;
      padding: 14px;
      color: #f5f6f9;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 10px;
    }
    
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(189, 0, 255, 0.3);
    }
    
    .btn:active {
      transform: translateY(0);
    }
    
    .footer-text {
      text-align: center;
      margin-top: 24px;
      font-size: 14px;
      color: var(--text-muted);
    }
    
    .footer-text a {
      color: #00e6ff;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s ease;
    }
    
    .footer-text a:hover {
      color: #bd00ff;
    }
    
    .error-alert {
      background: var(--error-bg);
      border: 1px solid rgba(255, 74, 90, 0.2);
      border-radius: 10px;
      padding: 12px 16px;
      color: var(--error-color);
      font-size: 14px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="header">
        <div class="logo">Create Account</div>
        <div class="subtitle">Join our secure SSO environment in seconds</div>
      </div>
      
      <% if (locals.error) { %>
        <div class="error-alert">
          <%= error %>
        </div>
      <% } %>
      
      <form action="/interaction/<%= uid %>/register" method="POST">
        <div class="form-group">
          <label class="form-label" for="name">Full Name</label>
          <input class="form-control" type="text" id="name" name="name" placeholder="John Doe" required autocomplete="name">
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email Address</label>
          <input class="form-control" type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email">
        </div>
        
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input class="form-control" type="password" id="password" name="password" placeholder="••••••••" required autocomplete="new-password">
        </div>
        
        <button class="btn" type="submit">Create Account</button>
      </form>
      
      <div class="footer-text">
        Already have an account? <a href="/interaction/<%= uid %>">Sign In</a>
      </div>
    </div>
  </div>
</body>
</html>
